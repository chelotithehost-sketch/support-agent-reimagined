# ── Environment ──────────────────────────────────────────────────
AFRI_ENV=dev
AFRI_DEBUG=true
AFRI_LOG_LEVEL=INFO
AFRI_SECRET_KEY=change-me-in-production

# ── API Server ───────────────────────────────────────────────────
AFRI_HOST=0.0.0.0
AFRI_PORT=8000
AFRI_WORKERS=4

# ── Redis ────────────────────────────────────────────────────────
AFRI_REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ───────────────────────────────────────────────────
AFRI_DATABASE_URL=postgresql+asyncpg://afriagent:afriagent@localhost:5432/afriagent

# ── Qdrant ───────────────────────────────────────────────────────
AFRI_QDRANT_URL=http://localhost:6333

# ── LLM Provider ─────────────────────────────────────────────────
# Options: openai, anthropic, ollama
AFRI_LLM_PROVIDER=openai

# OpenAI
AFRI_OPENAI_API_KEY=sk-your-key-here
AFRI_OPENAI_MODEL=gpt-4o

# Anthropic (alternative)
AFRI_ANTHROPIC_API_KEY=
AFRI_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (local, cost-controlled)
AFRI_OLLAMA_BASE_URL=http://localhost:11434
AFRI_OLLAMA_MODEL=llama3

# ── WhatsApp (Twilio) ────────────────────────────────────────────
AFRI_TWILIO_ACCOUNT_SID=
AFRI_TWILIO_AUTH_TOKEN=
AFRI_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Telegram ─────────────────────────────────────────────────────
AFRI_TELEGRAM_BOT_TOKEN=

# ── WHMCS ────────────────────────────────────────────────────────
AFRI_WHMCS_URL=
AFRI_WHMCS_IDENTIFIER=
AFRI_WHMCS_SECRET=

# ── M-Pesa ───────────────────────────────────────────────────────
AFRI_MPESA_CONSUMER_KEY=
AFRI_MPESA_CONSUMER_SECRET=
AFRI_MPESA_SHORTCODE=
AFRI_MPESA_PASSKEY=
AFRI_MPESA_CALLBACK_URL=https://yourdomain.com/webhooks/mpesa/callback

# ── Observability ────────────────────────────────────────────────
AFRI_OTEL_EXPORTER_ENDPOINT=http://localhost:4317
AFRI_METRICS_PORT=9090

# ── Self-Improvement ─────────────────────────────────────────────
AFRI_LEARNING_ENABLED=true
AFRI_MIN_CONFIDENCE_FOR_LEARNING=0.8
